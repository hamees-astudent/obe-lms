{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@fixtures": ["fixtures/index.ts"],
      "@fixtures/*": ["fixtures/*"],
      "@helpers/*": ["helpers/*"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "fixtures/**/*.ts",
    "helpers/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules"]
}
